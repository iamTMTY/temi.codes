---
// SpaceShooter Component - Integrates the game into the Hero section
---

<div class='space-shooter-container'>
  <div class='game-wrapper'>
    <canvas id='space-shooter-canvas'></canvas>
    <button id='sound-toggle' class='sound-toggle' aria-label='Toggle sound'>
      <span class='sound-icon sound-off'>🔇</span>
      <span class='sound-icon sound-on'>🔊</span>
    </button>
  </div>
</div>

<script>
  import { Game } from './Game';

  function initSpaceShooter() {
    const canvas = document.getElementById(
      'space-shooter-canvas',
    ) as HTMLCanvasElement;
    const soundToggle = document.getElementById(
      'sound-toggle',
    ) as HTMLButtonElement;
    const container = document.querySelector('.game-wrapper') as HTMLElement;

    if (!canvas || !soundToggle || !container) return;

    // Initial size
    const width = container.clientWidth;
    const height = container.clientHeight;

    const game = new Game(canvas, {
      width,
      height,
      backgroundColor: '#0a0a0a',
      primaryColor: '#50C878',
    });

    // Handle resizing
    const resizeObserver = new ResizeObserver((entries) => {
      for (const entry of entries) {
        const { width, height } = entry.contentRect;
        // Update canvas display size
        // Internal game resize logic handles the rest
        game.resize(width, height);
      }
    });

    resizeObserver.observe(container);

    game.start();

    // Sound toggle
    soundToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const enabled = game.toggleSound();
      soundToggle.classList.toggle('active', enabled);
    });

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      resizeObserver.disconnect();
      game.cleanup();
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSpaceShooter);
  } else {
    initSpaceShooter();
  }
</script>

<style>
  .space-shooter-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .game-wrapper {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    width: 100%;
    height: 100%;
  }

  #space-shooter-canvas {
    display: block;
    background: #0a0a0a;
    cursor: crosshair;
    width: 100%;
    height: 100%;
  }

  .sound-toggle {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background: rgba(20, 20, 20, 0.8);
    border: 1px solid rgba(80, 200, 120, 0.3);
    border-radius: 4px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 16px;
    transition: all 0.2s ease;
    z-index: 10;
    backdrop-filter: blur(5px);
  }

  .sound-toggle:hover {
    border-color: var(--color-primary, #50c878);
    background: rgba(20, 20, 20, 0.95);
    transform: translateY(-1px);
  }

  .sound-icon {
    display: inline-block;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .sound-toggle .sound-on {
    display: none;
  }

  .sound-toggle.active .sound-off {
    display: none;
  }

  .sound-toggle.active .sound-on {
    display: inline-block;
    opacity: 1;
  }

  .sound-toggle:not(.active) .sound-off {
    opacity: 1;
  }
</style>
