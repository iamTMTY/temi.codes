<style>
  #matrix-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: calc(100vh-0px);
    display: block;
    background: #000;
    z-index: -2;
  }

  .matrix-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: calc(100vh-0px);
    background: rgba(0, 0, 0, 0.7);
    z-index: -1;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #matrix-canvas,
    .matrix-overlay,
    .matrix-fab {
      display: none;
    }
    body {
      background: #000;
    }
  }

  .matrix-fab {
    position: fixed;
    bottom: calc(1.5rem + env(safe-area-inset-bottom, 0));
    right: 1.5rem;
    z-index: 1001;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-bg-accent, #1a1a1a);
    border: 1px solid var(--color-primary, #50c278);
    color: var(--color-primary, #50c278);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  @media (max-width: 768px) {
    .matrix-fab {
      bottom: calc(80px + env(safe-area-inset-bottom, 0));
    }
  }

  .matrix-fab:hover {
    background: rgba(80, 194, 120, 0.1);
    transform: scale(1.05);
  }

  .matrix-fab .motion-icon {
    width: 36px;
    height: 36px;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    color: var(--color-primary, #50c278);
  }

  .matrix-fab .motion-playing {
    opacity: 0.9;
  }

  .matrix-fab .hidden {
    display: none;
  }
</style>
