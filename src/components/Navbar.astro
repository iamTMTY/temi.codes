<nav class='navbar-mobile-bottom'>
  <div class='container navbar-content'>
    <ul class='nav-links'>
      <li><a href='#work'>Work</a></li>
      <li><a href='#about'>About</a></li>
      <li><a href='#contact'>Contact</a></li>
    </ul>
  </div>
