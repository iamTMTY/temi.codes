---
const projects = [
  {
    title: 'Kutlass',
    category: 'Video Processing',
    description:
      'A fully client-side browser video editor React component. All video processing — decoding, effects, cropping, annotations, and encoding — runs entirely in the browser using WebCodecs and FFmpeg WASM. No server required.',
    image: '',
    link: 'https://kutlass.vercel.app/',
  },
  {
    title: 'A11y Auditor',
    category: 'Accessibility',
    description:
      'An accessibility auditing tool built with Next.js, axe-core and Playwright. This application allows developers and designers to scan websites or HTML snippets for WCAG violations and offers actionable remediation steps with visual context.',
    image: '',
    link: 'https://a11y-auditor.vercel.app/',
  },
  {
    title: 'Space Conqueror',
    category: 'Canvas Game',
    description:
      'Space Conqueror is a fast-paced, neon-infused arcade "bullet hell" survival game built with TypeScript/JavaScript and HTML5 Canvas. Players pilot a high-tech starship through an increasingly chaotic asteroid field and enemy territory.',
    image: '',
    link: 'https://space-conqueror-sable.vercel.app',
  },
];
---

<section id='work' class='projects-section'>
  <div class='container'>
    <h2 class='section-title reveal'>
      Selected <span class='highlight'>Projects</span>
    </h2>

    <div class='projects-grid'>
      {
        projects.map((project, index) => (
          <article
            class={`project-card reveal ${index === 1 ? 'delay-100' : index === 2 ? 'delay-200' : ''}`}
          >
            <div class='card-content'>
              <div>
                <h3>{project.title}</h3>
                <span class='category'>{project.category}</span>
                <p>{project.description}</p>
              </div>
              <a target='_blank' href={project.link} class='link-arrow'>
                View Project <span>&rarr;</span>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: var(--spacing-xl) 0;
  }

  .highlight {
    color: var(--color-primary);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .project-card {
    /* background: var(--color-bg-card); */
    background: rgba(0, 0, 0, 0.3);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-bg-accent);
    border-radius: var(--border-radius);
    overflow: hidden;
    position: relative;
  }

  /* .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    border-color: var(--color-primary-dim);
  }

  .project-card:hover .card-image img {
    opacity: 1;
  } */

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }

  .category {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    display: block;
    margin-bottom: 0.5rem;
  }

  .card-content h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin: 0 0 0.75rem 0;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .card-content p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .link-arrow {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-main);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    letter-spacing: 0.03em;
  }

  .link-arrow span {
    transition: transform 0.2s ease;
  }

  .link-arrow:hover span {
    transform: translateX(4px);
  }

  .link-arrow:hover {
    color: var(--color-primary);
  }
</style>
